# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql://roomstyle_admin:PASSWORD@roomstyle-db.xxxx.ap-southeast-1.rds.amazonaws.com:5432/roomstyle

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
S3_BUCKET=roomstyle-cs5224

# For local development only — on Lambda, the execution role provides credentials
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
